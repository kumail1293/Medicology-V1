# Environment Variables Reference
# Copy this as .env in the root and fill in actual values
# NEVER commit the actual .env file - keep secrets secure!

# ==========================================
# Backend API Configuration (api-server)
# ==========================================

# Database Connection
# Format: postgresql://username:password@host:port/database
# Get this from Railway or Neon or Supabase
DATABASE_URL=postgresql://user:password@localhost:5432/medicology

# JWT Secret for Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters and kept secure
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Node Environment
# Values: development | production | staging
NODE_ENV=development

# Backend Port
PORT=3000

# CORS Configuration (comma-separated URLs)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ==========================================
# Frontend Configuration (medicology)
# ==========================================

# API URL - Points to backend server
# Development: http://localhost:3000
# Production: https://api-xxxxx.railway.app
VITE_API_URL=http://localhost:3000

# ==========================================
# Email Configuration (Optional)
# ==========================================

# SMTP Server for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ==========================================
# Payment Gateway (Optional)
# ==========================================

# For Razorpay or payment processing
RAZORPAY_KEY_ID=your-key-id
RAZORPAY_KEY_SECRET=your-key-secret

# ==========================================
# Analytics & Monitoring (Optional)
# ==========================================

# Sentry for error tracking (free tier available)
SENTRY_DSN=

# ==========================================
# Deployment Environments
# ==========================================

# For Railway deployment:
# - DATABASE_URL from Railway PostgreSQL instance
# - JWT_SECRET: Set a secure value
# - NODE_ENV: production
# - PORT: Railway auto-assigns

# For Vercel deployment:
# - VITE_API_URL: Your Railway API URL
# - No other variables needed for frontend

# For Local Development:
# - DATABASE_URL: Local PostgreSQL
# - VITE_API_URL: http://localhost:3000
# - JWT_SECRET: Any value (not used in dev typically)
# - NODE_ENV: development
